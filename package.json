{
  "name": "mystery",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r run build",
    "build:packages": "pnpm --filter @mystery/shared build && pnpm --filter @mystery/engine build && pnpm --filter @mystery/llm build",
    "schema": "pnpm --filter @mystery/shared schema",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "dev:api": "pnpm run build:packages && pnpm --filter @mystery/api dev",
    "dev:web": "pnpm --filter @mystery/web dev",
    "publish-case": "node apps/api/scripts/publish-case.mjs",
    "dev:studio": "pnpm --filter @mystery/studio dev",
    "deploy:api": "fly deploy -c fly.api.toml",
    "deploy:web": "fly deploy -c fly.web.toml"
  },
  "engines": {
    "node": ">=20"
  }
}
