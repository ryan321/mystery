  "meta": {
    "title": "Hostile Takeover",
    "premise": "A tech CEO falls from a penthouse boardroom the night before a billion-dollar merger. Everyone inside had a reason to push.",
    "tone": "corporate thriller, glass and steel, clipped ambition",
    "tags": [
      "Corporate",
      "Office",
      "Espionage",
      "Modern"
    ],
    "difficulty": "medium",
    "contentWarnings": [
      "murder",
      "suicide discussion"
    ],
    "artStyle": "Corporate noir portrait, head-and-shoulders, cool glass-tower blue and charcoal, executive fashion, same polished boardroom lighting for every cast member, mystery game NPC portrait",
    "setting": "A glass penthouse boardroom, fifty floors up. Night before the merger vote. City lights like a circuit board.",
    "summary": "CEO Ava Krane is dead on the terrace setback below — she went over the boardroom balcony during a late session. Present: CFO Marcus Bell, activist investor Cole Grant, general counsel Priya Shah, VP Product Jordan Lee, and exec assistant Noah Kim. Tomorrow’s merger is worth a fortune to the people who shorted it and a disaster to the people who didn’t. Someone in that room decided Ava would not live to ring the open bell.",
    "theMystery": "Who pushed Ava Krane from the boardroom balcony — and what about the merger made murder cheaper than a vote?"
  },
  "player": {
    "displayName": "Investigator",
    "addressAs": "Investigator",
    "pronouns": "they/them",
    "role": "Independent investigator retained by the board chair before counsel locks the floor",
    "authority": "professional",
    "age": "forties",
    "appearance": "Boardroom-appropriate; nothing flashy",
    "clothing": "Dark suit, soft-soled shoes, a notebook instead of a phone at the table",
    "background": "Brought in the same night as the fall — paid to ask questions security and GC would rather control.",
    "publicPerception": "An outside problem with access. Executives perform; juniors panic.",
    "voiceNotes": "Measured, corporate-fluent, hard to charm",
    "performanceNotes": "No badge. Authority is contractual and temporary. Cole will lawyer up; Marcus may cooperate.",
    "startingLocationId": "boardroom",
    "startingEvidenceIds": [],
    "startingKnowledge": "CEO Ava Krane is dead on the terrace setback fifty floors down — fell from the boardroom balcony. Present for the late session: CFO Marcus Bell, GC Priya Shah, VP Product Jordan Lee, activist investor Cole Grant, exec assistant Noah Kim. Merger vote was tomorrow. Security says the balcony door was open.",
    "objective": "Work the boardroom, balcony, and offices; follow the money and the threats; and accuse the killer with method and motive before counsel shuts the building down."
  },
  "openingNarration": "Floor-to-ceiling glass. The city is a circuit board of lights. In the boardroom, water glasses still sit at six places. One chair is empty — Ava’s. The balcony door is open to a cold wind. Fifty floors below, emergency lights paint the terrace setback where Ava Krane landed. The people who were in this room for the late session are still here: Marcus, Cole, Priya, Jordan, Noah — each with a story about where they stood when she “fell.” Tomorrow’s merger does not care about grief. You do. Find who pushed her, and why the deal was worth a body.",
