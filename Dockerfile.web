# MysteryTrove web — build from the repo root:
#   fly deploy -c fly.web.toml        (or: docker build -f Dockerfile.web .)
#
# NEXT_PUBLIC_API_URL is baked into the client bundle at BUILD time —
# set it via [build.args] in fly.web.toml.
FROM node:22-slim AS base
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable
WORKDIR /app

# ── Build ────────────────────────────────────────────────────────────
FROM base AS build
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY packages/shared/package.json packages/shared/
COPY apps/web/package.json apps/web/
RUN pnpm install --frozen-lockfile --filter "@mystery/web..."

COPY packages/shared packages/shared
RUN pnpm --filter "@mystery/shared" build
COPY apps/web apps/web
RUN pnpm --filter "@mystery/web" build

# ── Run (Next standalone output) ─────────────────────────────────────
FROM base AS run
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000
COPY --from=build /app/apps/web/.next/standalone ./
COPY --from=build /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=build /app/apps/web/public ./apps/web/public
EXPOSE 3000
CMD ["node", "apps/web/server.js"]
