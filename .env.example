# Copy to .env and fill in values:
#   cp .env.example .env

# --- Database ---
# Local Postgres (create once: psql -d postgres -c "CREATE DATABASE mystery;")
DATABASE_URL=postgres://localhost:5432/mystery

# --- LLM (OpenRouter) ---
# Required for live AI narrator. Without it, the API uses a heuristic fallback.
OPENROUTER_API_KEY=

# Optional model overrides (OpenRouter model ids)
# Both calls default to anthropic/claude-sonnet-5 when unset.
# Call #2 — performer / narrator (prose)
LLM_NARRATOR_MODEL=anthropic/claude-sonnet-5
# Call #1 — director / intents (same model for now)
LLM_DIRECTOR_MODEL=anthropic/claude-sonnet-5

# Optional custom base URL (default is fine for OpenRouter)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- API ---
PORT=8787

# --- Web (Next.js) ---
# NEXT_PUBLIC_API_URL=http://localhost:8787
